{
  "type": "APL",
  "version": "2024.2",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["summaryData"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "paddingLeft": "40dp",
        "paddingRight": "40dp",
        "paddingTop": "30dp",
        "paddingBottom": "20dp",
        "items": [
          {
            "type": "Container",
            "direction": "row",
            "alignItems": "center",
            "paddingBottom": "16dp",
            "items": [
              {
                "type": "Text",
                "text": "Nachrichten-Zusammenfassung",
                "color": "white",
                "fontSize": "32dp",
                "fontWeight": "bold",
                "grow": 1
              },
              {
                "type": "Text",
                "text": "${summaryData.properties.timestamp}",
                "color": "#78909C",
                "fontSize": "18dp"
              }
            ]
          },
          {
            "type": "ScrollView",
            "id": "summaryScroll",
            "width": "100%",
            "grow": 1,
            "items": [
              {
                "type": "Container",
                "width": "100%",
                "items": [
                  {
                    "type": "Text",
                    "text": "${summaryData.properties.summaryMarkup}",
                    "color": "white",
                    "fontSize": "24dp",
                    "lineHeight": "1.5",
                    "paddingBottom": "24dp"
                  },
                  {
                    "type": "Text",
                    "text": "Quellen",
                    "color": "#4FC3F7",
                    "fontSize": "22dp",
                    "fontWeight": "bold",
                    "paddingBottom": "8dp"
                  },
                  {
                    "type": "Container",
                    "width": "100%",
                    "data": "${summaryData.properties.sources}",
                    "items": [
                      {
                        "type": "Container",
                        "direction": "row",
                        "alignItems": "center",
                        "paddingBottom": "6dp",
                        "items": [
                          {
                            "type": "Image",
                            "source": "${data.logo}",
                            "width": "24dp",
                            "height": "24dp",
                            "borderRadius": "4dp",
                            "marginRight": "8dp"
                          },
                          {
                            "type": "Text",
                            "text": "${data.title} (${data.channel})",
                            "color": "#B0BEC5",
                            "fontSize": "18dp"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "onMount": [
    {
      "type": "Scroll",
      "componentId": "summaryScroll",
      "distance": "100vh",
      "targetDuration": 120000
    }
  ]
}
