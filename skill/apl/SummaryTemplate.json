{
  "type": "APL",
  "version": "2024.2",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["summaryData"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "paddingLeft": "40dp",
        "paddingRight": "40dp",
        "paddingTop": "30dp",
        "paddingBottom": "20dp",
        "items": [
          {
            "type": "Container",
            "direction": "row",
            "alignItems": "center",
            "paddingBottom": "16dp",
            "items": [
              {
                "type": "Text",
                "text": "Nachrichten-Zusammenfassung",
                "color": "white",
                "fontSize": "32dp",
                "fontWeight": "bold",
                "grow": 1
              },
              {
                "type": "Text",
                "text": "${summaryData.properties.timestamp}",
                "color": "#78909C",
                "fontSize": "18dp"
              }
            ]
          },
          {
            "type": "ScrollView",
            "width": "100%",
            "grow": 1,
            "items": [
              {
                "type": "Container",
                "width": "100%",
                "items": [
                  {
                    "type": "Text",
                    "text": "${summaryData.properties.summaryText}",
                    "color": "white",
                    "fontSize": "24dp",
                    "lineHeight": "1.5",
                    "paddingBottom": "24dp"
                  },
                  {
                    "type": "Text",
                    "text": "Quellen",
                    "color": "#4FC3F7",
                    "fontSize": "22dp",
                    "fontWeight": "bold",
                    "paddingBottom": "8dp"
                  },
                  {
                    "type": "Container",
                    "width": "100%",
                    "data": "${summaryData.properties.sources}",
                    "items": [
                      {
                        "type": "Text",
                        "text": "${data.title} (${data.channel})",
                        "color": "#B0BEC5",
                        "fontSize": "18dp",
                        "paddingBottom": "4dp"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
