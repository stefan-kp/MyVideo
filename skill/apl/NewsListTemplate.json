{
  "type": "APL",
  "version": "2024.2",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["newsData"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "paddingLeft": "40dp",
        "paddingRight": "40dp",
        "paddingTop": "30dp",
        "paddingBottom": "20dp",
        "items": [
          {
            "type": "Text",
            "text": "${newsData.properties.title}",
            "color": "white",
            "fontSize": "32dp",
            "fontWeight": "bold",
            "paddingBottom": "16dp"
          },
          {
            "type": "Sequence",
            "width": "100%",
            "grow": 1,
            "scrollDirection": "vertical",
            "data": "${newsData.properties.sections}",
            "items": [
              {
                "type": "Container",
                "width": "100%",
                "paddingBottom": "8dp",
                "items": [
                  {
                    "type": "Text",
                    "text": "${data.title}",
                    "color": "#4FC3F7",
                    "fontSize": "24dp",
                    "fontWeight": "bold",
                    "paddingTop": "12dp",
                    "paddingBottom": "10dp"
                  },
                  {
                    "type": "Container",
                    "width": "100%",
                    "data": "${data.results}",
                    "items": [
                      {
                        "type": "TouchWrapper",
                        "onPress": [
                          {
                            "type": "SendEvent",
                            "arguments": ["selectResult", "${data.flatIndex}"]
                          }
                        ],
                        "items": [
                          {
                            "type": "Frame",
                            "backgroundColor": "${data.flatIndex % 2 == 0 ? 'rgba(255,255,255,0.08)' : 'rgba(255,255,255,0.03)'}",
                            "borderRadius": "12dp",
                            "paddingLeft": "20dp",
                            "paddingRight": "20dp",
                            "paddingTop": "14dp",
                            "paddingBottom": "14dp",
                            "marginBottom": "8dp",
                            "items": [
                              {
                                "type": "Container",
                                "direction": "row",
                                "alignItems": "center",
                                "items": [
                                  {
                                    "type": "Text",
                                    "text": "${data.flatIndex + 1}",
                                    "color": "#4FC3F7",
                                    "fontSize": "28dp",
                                    "fontWeight": "bold",
                                    "width": "40dp"
                                  },
                                  {
                                    "type": "Image",
                                    "source": "${data.imageUrl != '' ? data.imageUrl : data.logo}",
                                    "width": "${data.imageUrl != '' ? '80dp' : '40dp'}",
                                    "height": "${data.imageUrl != '' ? '45dp' : '40dp'}",
                                    "borderRadius": "6dp",
                                    "scale": "best-fit",
                                    "when": "${data.imageUrl != '' || data.logo != ''}"
                                  },
                                  {
                                    "type": "Container",
                                    "grow": 1,
                                    "paddingLeft": "12dp",
                                    "items": [
                                      {
                                        "type": "Text",
                                        "text": "${data.title}",
                                        "color": "white",
                                        "fontSize": "22dp",
                                        "fontWeight": "bold",
                                        "maxLines": 2
                                      },
                                      {
                                        "type": "Container",
                                        "direction": "row",
                                        "paddingTop": "4dp",
                                        "items": [
                                          {
                                            "type": "Text",
                                            "text": "${data.channel}",
                                            "color": "#B0BEC5",
                                            "fontSize": "18dp"
                                          },
                                          {
                                            "type": "Text",
                                            "text": " · ${data.time}",
                                            "color": "#78909C",
                                            "fontSize": "18dp"
                                          },
                                          {
                                            "type": "Text",
                                            "text": " · ${data.duration}",
                                            "color": "#78909C",
                                            "fontSize": "18dp",
                                            "when": "${data.duration != ''}"
                                          }
                                        ]
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Text",
            "text": "Tippe auf einen Eintrag oder sage eine Nummer.",
            "color": "#78909C",
            "fontSize": "16dp",
            "paddingTop": "10dp",
            "textAlign": "center"
          }
        ]
      }
    ]
  }
}
