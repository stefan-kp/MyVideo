# MyVideo Alexa Skill - Konfiguration
#
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# Port fuer den Express Server
PORT=3000

# Externe URL (ngrok oder Cloudflare Tunnel)
# Diese URL wird als Video-Stream URL an Alexa gesendet
# Beispiel: https://xxxx-xxxx.ngrok-free.app
BASE_URL=

# Fritz!Box DVB-C Stream URL
# Die URL findest du in der Fritz!Box unter Heimnetz > Mediaserver > DVB-C
# Der sid-Parameter ist die Session-ID der Fritz!Box Web-Oberflaeche
STREAM_URL=http://192.168.100.1/dvb/m3u/51400_15030.m3u?sid=YOUR_SESSION_ID
