# MyVideo Alexa Skill - Konfiguration
#
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# Port fuer den Express Server (intern im Container)
PORT=3000

# Externer Port (Host-Seite, nur fuer docker-compose)
PORT_EXTERNAL=3377

# Externe URL (Cloudflare Tunnel)
# Diese URL wird als Video-Stream URL an Alexa gesendet
BASE_URL=https://tv.example.de

# JWT Secret fuer Proxy-Absicherung (min 32 Zeichen)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Cloudflare Tunnel
TUNNEL_HOSTNAME=tv.example.de
TUNNEL_CNAME=<tunnel-id>.cfargotunnel.com
TUNNEL_TOKEN=

# Region: AT oder DE
# Bestimmt Reihenfolge und Auswahl der Nachrichten, Sport- und Kultursendungen
# AT: ZIB zuerst, Sport-Bild (ORF), kulturMONTAG
# DE: Tagesschau zuerst, Sportschau (ARD), Kulturzeit
REGION=AT

# Alexa Skill
SKILL_ID=

# AI Summary (optional)
# OPENROUTER_API_KEY=sk-or-...      # OpenRouter API Key fuer Zusammenfassung
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite  # LLM Model (Standard: Gemini Flash)

# ORF TVthek API (optional)
# Direkte ORF-Anbindung fuer aktuellere Inhalte, Vorschaubilder und Kapitel-Navigation
# ORF_API=true

# Optional: Fritz!Box DVB-C Stream (Phase 2, noch nicht implementiert)
# Wird aktuell nicht vom Server verwendet - nur vom manuellen Script scripts/start-stream.sh
# STREAM_URL=http://fritz.box/dvb/m3u/51400_15030.m3u?sid=YOUR_SESSION_ID
